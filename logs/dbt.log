    as (

WITH source AS (

    SELECT *
    FROM REAL_ESTATE_DB.BRONZE.RAW_LISTINGS

),

cleaned AS (

    SELECT

        listing_id,

        INITCAP(TRIM(property_type))        AS property_type,
        INITCAP(TRIM(country))              AS country,
        INITCAP(TRIM(city))                 AS city,
        INITCAP(TRIM(neighborhood))         AS neighborhood,

        TRY_TO_NUMBER(surface_m2)           AS surface_m2,
        TRY_TO_NUMBER(num_rooms)            AS num_rooms,
        TRY_TO_NUMBER(num_bathrooms)        AS num_bathrooms,
        TRY_TO_NUMBER(floor)                AS floor,
        TRY_TO_NUMBER(year_built)           AS year_built,

        TRY_TO_NUMBER(
            REGEXP_REPLACE(price,'[^0-9.]','')
        ) AS price,

        COALESCE(
            TRY_TO_DATE(listing_date,'YYYY-MM-DD'),
            TRY_TO_DATE(listing_date,'DD/MM/YYYY'),
            TRY_TO_DATE(listing_date,'MM/DD/YYYY')
        ) AS listing_date,

        INITCAP(TRIM(condition)) AS property_condition,

        INITCAP(TRIM(heating_type)) AS heating_type,

        CASE
            WHEN LOWER(TRIM(parking)) IN ('yes','y','true','1')
                THEN 'Yes'
            WHEN LOWER(TRIM(parking)) IN ('no','n','false','0')
                THEN 'No'
            ELSE NULL
        END AS parking,

        UPPER(TRIM(energy_rating)) AS energy_rating,

        ROW_NUMBER() OVER(
            PARTITION BY listing_id
            ORDER BY listing_date DESC
        ) AS rn

    FROM source

)

SELECT

    listing_id,
    property_type,
    country,
    city,
    neighborhood,
    surface_m2,
    num_rooms,
    num_bathrooms,
    floor,
    year_built,
    price,
    listing_date,
    condition,
    heating_type,
    parking,
    energy_rating

FROM cleaned

WHERE rn = 1
    AND price BETWEEN 10000 AND 100000000
    AND surface_m2 BETWEEN 10 AND 5000
    )

